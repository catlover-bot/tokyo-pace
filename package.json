{
  "name": "tokyo-pace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:api-contract": "vitest run tests/workerRoutes.test.ts && node scripts/verify-api-contract.mjs",
    "data:update": "node scripts/update-open-data.mjs",
    "data:verify-determinism": "node scripts/verify-data-determinism.mjs",
    "verify:accessibility": "node scripts/verify-accessibility.mjs",
    "verify:bundle-budget": "node scripts/verify-bundle-budget.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "verify:secrets": "node scripts/verify-secrets.mjs",
    "verify:release-config": "node scripts/verify-release-candidate.mjs",
    "verify:production": "node scripts/verify-production.mjs",
    "release:preview": "node scripts/release-preview.mjs",
    "smoke:preview": "node scripts/smoke-preview.mjs",
    "deploy": "node scripts/production-deploy-guard.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "^1.45.0",
    "@cloudflare/workers-types": "^5.20260717.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
