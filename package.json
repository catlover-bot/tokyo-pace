{
  "name": "tokyo-pace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "data:update": "node scripts/update-open-data.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@cloudflare/workers-types": "^5.20260717.1",
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
